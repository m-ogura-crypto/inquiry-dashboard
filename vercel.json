// State
let selectedMonths = new Set();
let selectedBranches = new Set();
let selectedTypes = new Set();
let allYearMonths = [];
let allBranches = [];
let allTypes = [];
let DATA = [];

// Charts
let chartMonthly, chartType;

async function init() {
  // まず埋め込みデータで即時表示
  DATA = RAW_DATA;
  allYearMonths = [...new Set(DATA.map(r => r.ym))].filter(Boolean).sort();
  allBranches = [...new Set(DATA.map(r => r.branch).filter(Boolean))].sort();
  const last6 = allYearMonths.slice(-6);
  last6.forEach(m => selectedMonths.add(m));
  buildSidebar();
  update();

  // バックグラウンドでkintoneから最新データを自動取得
  const status = document.getElementById('csv-status');
  const btn = document.getElementById('kintone-btn');
  status.textContent = '最新データを取得中...';
  document.getElementById('loading-sub').textContent = 'kintoneに接続しています...';
  btn.disabled = true;
  btn.innerHTML = `<svg width="13" height="13" viewBox="0 0 16 16" fill="none" style="flex-shrink:0;animation:spin 1s linear infinite"><path d="M13.5 8A5.5 5.5 0 1 1 8 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg> 取得中...`;

  try {
    const res = await fetch('/api/kintone');
    if (!res.ok) throw new Error(`サーバーエラー: ${res.status}`);
    const json = await res.json();
    if (json.error) throw new Error(json.error);

    DATA = json.records;
    allYearMonths = [...new Set(DATA.map(r => r.ym))].filter(Boolean).sort();
    allBranches = [...new Set(DATA.map(r => r.branch).filter(Boolean))].sort();
    selectedMonths = new Set(allYearMonths.slice(-6));
    selectedBranches = new Set();
    selectedTypes = new Set(); // クリアしてからbuildSidebarでデフォルト設定
    allTypes = []; // allTypesもリセットしてbuildSidebar内で再構築させる
    buildSidebar();
    update();

    const now = new Date();
    const dateStr = `${now.getFullYear()}年${now.getMonth()+1}月${now.getDate()}日 ${String(now.getHours()).padStart(2,'0')}:${String(now.getMinutes()).padStart(2,'0')}`;
    document.getElementById('update-date').textContent = `kintone連携 ${dateStr}`;
    status.textContent = `✓ ${json.total.toLocaleString()}件 取得完了`;
    status.className = 'csv-status csv-ok';
  } catch(err) {
    status.textContent = `自動取得失敗：${err.message}`;
    status.className = 'csv-status csv-err';
    document.getElementById('update-date').textContent = '埋め込みデータ（自動取得失敗）';
  } finally {
    // ローディング非表示
    const overlay = document.getElementById('loading-overlay');
    overlay.classList.add('hidden');
    setTimeout(() => overlay.style.display = 'none', 400);
    btn.disabled = false;
    btn.innerHTML = `<svg width="13" height="13" viewBox="0 0 16 16" fill="none" style="flex-shrink:0"><path d="M13.5 8A5.5 5.5 0 1 1 8 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M10 2h4v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M14 2l-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg> kintoneから取得`;
  }
}




// ── Branch monthly chart ──────────────────────────────────────────────
let chartBranch;
const BRANCH_COLORS = [
  '#6c8fff','#a78bfa','#22d3ee','#34d399','#fbbf24',
  '#f87171','#fb923c','#e879f9','#4ade80','#38bdf8',
  '#a3e635','#818cf8','#fb7185','#67e8f9','#c084fc','#94a3b8'
];

function updateBranchChart(filtered) {
  // X軸：支店（指定順）
  const BRANCH_ORDER = ['西東京','東東京','神奈川','名古屋','中日本','大阪','中四国','WE'];
  const branchTotals = {};
  filtered.forEach(r => { if(r.branch) branchTotals[r.branch] = (branchTotals[r.branch]||0)+1; });
  // 指定順の支店のみ表示（データに存在するもの）
  const branches = BRANCH_ORDER.filter(b => branchTotals[b] !== undefined);

  // 積み上げ：問合わせ種別（件数多い順 上位8種＋その他）
  const typeTotals = {};
  filtered.forEach(r => { if(r.type && r.type!=='---') typeTotals[r.type]=(typeTotals[r.type]||0)+1; });
  const allTypes = Object.entries(typeTotals).sort((a,b)=>b[1]-a[1]).map(([t])=>t);
  const topTypes = allTypes.slice(0, 8);
  const otherTypes = allTypes.slice(8);

  const datasets = topTypes.map(t => ({
    label: t,
    data: branches.map(br => filtered.filter(r => r.branch===br && r.type===t).length),
    backgroundColor: TYPE_COLORS[t] || '#6b7280',
    borderWidth: 0,
    borderRadius: 2,
  }));
  if (otherTypes.length > 0) {
    datasets.push({
      label: 'その他',
      data: branches.map(br => filtered.filter(r => r.branch===br && otherTypes.includes(r.type)).length),
      backgroundColor: '#374151',
      borderWidth: 0,
      borderRadius: 2,
    });
  }

  if (chartBranch) chartBranch.destroy();
  const ctx = document.getElementById('chart-branch').getContext('2d');
  chartBranch = new Chart(ctx, {
    type: 'bar',
    data: { labels: branches, datasets },
    options: {
      plugins: { legend: { labels: { color:'#9097b8', font:{size:10}, boxWidth:10, padding:8 }, position:'bottom' } },
      scales: {
        x: { stacked:true, ticks:{color:'#5c6280',font:{size:11}}, grid:{color:'rgba(255,255,255,0.04)'} },
        y: { stacked:true, ticks:{color:'#5c6280',font:{size:11}}, grid:{color:'rgba(255,255,255,0.06)'} },
      },
      responsive:true, maintainAspectRatio:true,
    }
  });
}

// ── kintone API loader ───────────────────────────────────────────────────
async function loadFromKintone() {
  const btn = document.getElementById('kintone-btn');
  const status = document.getElementById('csv-status');
  btn.disabled = true;
  btn.innerHTML = `<svg width="13" height="13" viewBox="0 0 16 16" fill="none" style="flex-shrink:0;animation:spin 1s linear infinite"><path d="M13.5 8A5.5 5.5 0 1 1 8 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg> 取得中...`;
  status.textContent = 'kintoneからデータ取得中...';
  status.className = 'csv-status';

  try {
    const res = await fetch('/api/kintone');
    if (!res.ok) throw new Error(`サーバーエラー: ${res.status}`);
    const json = await res.json();
    if (json.error) throw new Error(json.error);

    DATA = json.records;
    allYearMonths = [...new Set(DATA.map(r => r.ym))].filter(Boolean).sort();
    allBranches = [...new Set(DATA.map(r => r.branch).filter(Boolean))].sort();
    selectedMonths = new Set(allYearMonths.slice(-6));
    selectedBranches = new Set();
    buildSidebar();
    update();

    const now = new Date();
    const dateStr = `${now.getFullYear()}年${now.getMonth()+1}月${now.getDate()}日 ${String(now.getHours()).padStart(2,'0')}:${String(now.getMinutes()).padStart(2,'0')}`;
    document.getElementById('update-date').textContent = `kintone連携 ${dateStr}`;
    status.textContent = `✓ ${json.total.toLocaleString()}件 取得完了`;
    status.className = 'csv-status csv-ok';
  } catch(err) {
    status.textContent = 'エラー: ' + err.message;
    status.className = 'csv-status csv-err';
  } finally {
    btn.disabled = false;
    btn.innerHTML = `<svg width="13" height="13" viewBox="0 0 16 16" fill="none" style="flex-shrink:0"><path d="M13.5 8A5.5 5.5 0 1 1 8 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M10 2h4v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M14 2l-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg> kintoneから取得`;
  }
}


document.getElementById('csv-input').addEventListener('change', function(e) {
  const file = e.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = function(ev) {
    try {
      const text = ev.target.result;
      const parsed = parseCSV(text);
      if (parsed.length === 0) throw new Error('データが空です');
      DATA = parsed;
      allYearMonths = [...new Set(DATA.map(r => r.ym))].filter(Boolean).sort();
      allBranches = [...new Set(DATA.map(r => r.branch).filter(Boolean))].sort();
      selectedMonths = new Set(allYearMonths);
      selectedBranches = new Set();
      buildSidebar();
      update();
      document.getElementById('csv-status').textContent = `✓ ${file.name}（${parsed.length.toLocaleString()}件）`;
      document.getElementById('csv-status').className = 'csv-status csv-ok';
      // Update date bar
      const now = new Date();
      const dateStr = `${now.getFullYear()}年${now.getMonth()+1}月${now.getDate()}日 ${String(now.getHours()).padStart(2,'0')}:${String(now.getMinutes()).padStart(2,'0')} （${file.name}）`;
      document.getElementById('update-date').textContent = dateStr;
      document.getElementById('csv-label').style.borderColor = 'var(--green)';
      document.getElementById('csv-label').style.color = 'var(--green)';
    } catch(err) {
      document.getElementById('csv-status').textContent = 'エラー: ' + err.message;
      document.getElementById('csv-status').className = 'csv-status csv-err';
    }
  };
  reader.readAsText(file, 'UTF-8');
  e.target.value = '';
});

function parseCSV(text) {
  // Handle BOM
  if (text.charCodeAt(0) === 0xFEFF) text = text.slice(1);
  const lines = text.split(/\r?\n/).filter(l => l.trim());
  if (lines.length < 2) throw new Error('ヘッダー行とデータ行が必要です');

  const headers = lines[0].split(',').map(h => h.trim().replace(/^"|"$/g, ''));

  // Column name mapping (flexible)
  const colMap = {
    ym:     ['お問合せ年月(yyyy-mm)','お問合せ年月(YYYY-MM)','お問合せ年月','yearmonth','ym'],
    branch: ['支店','branch'],
    type:   ['問合わせ種別','問合せ種別','type'],
    rank:   ['ランク','rank'],
    pref:   ['都道府県','pref'],
    tantou: ['主担当者','tantou'],
    meibo:  ['名簿取得者','meibo'],
  };

  const idx = {};
  for (const [key, candidates] of Object.entries(colMap)) {
    for (const c of candidates) {
      const i = headers.findIndex(h => h === c);
      if (i >= 0) { idx[key] = i; break; }
    }
  }
  if (idx.ym === undefined) throw new Error('「お問合せ年月」列が見つかりません');

  return lines.slice(1).map(line => {
    const cols = line.split(',').map(c => c.trim().replace(/^"|"$/g, ''));
    return {
      ym:     cols[idx.ym]     || null,
      branch: cols[idx.branch] || '',
      type:   cols[idx.type]   || '---',
      rank:   cols[idx.rank]   || '---',
      pref:   cols[idx.pref]   || '',
      tantou: cols[idx.tantou] || '',
      meibo:  cols[idx.meibo]  || '',
    };
  }).filter(r => r.ym && /^\d{4}-\d{2}$/.test(r.ym));
}

// Rebuild sidebar without duplicating (reset containers)
function buildSidebar() {
  document.getElementById('year-tabs').innerHTML = '';
  document.getElementById('month-grid').innerHTML = '';
  document.getElementById('branch-chips').innerHTML = '';
  const years = [...new Set(allYearMonths.map(m => m.slice(0,4)))].sort();
  const ytabs = document.getElementById('year-tabs');
  years.forEach(y => {
    const b = document.createElement('button');
    b.className = 'year-tab';
    b.textContent = y;
    b.onclick = () => toggleYear(y, b);
    ytabs.appendChild(b);
  });
  buildMonthGrid();
  const bc = document.getElementById('branch-chips');
  allBranches.forEach(br => {
    const c = document.createElement('div');
    c.className = 'chip';
    c.textContent = br;
    c.dataset.branch = br;
    c.onclick = () => toggleBranch(br, c);
    bc.appendChild(c);
  });

  // 種別チップ
  allTypes = [...new Set(DATA.map(r => r.type).filter(t => t))];
  // 件数多い順にソート
  allTypes.sort((a,b) => DATA.filter(r=>r.type===b).length - DATA.filter(r=>r.type===a).length);
  const tc = document.getElementById('type-chips');
  tc.innerHTML = '';
  // selectedTypesが空のときは常にニセコミライ以外を全選択（デフォルト）
  if (selectedTypes.size === 0) {
    allTypes.forEach(t => { if (t !== 'ニセコミライ') selectedTypes.add(t); }); // ---も含む
  }
  allTypes.forEach(t => {
    const c = document.createElement('div');
    c.className = 'chip';
    c.textContent = t === '---' ? '未設定' : t;
    c.dataset.type = t;
    c.onclick = () => toggleType(t, c);
    if (selectedTypes.has(t)) c.classList.add('active');
    tc.appendChild(c);
  });
  updateTypeCount();
}

function buildSidebarLegacy() {
  // Year tabs
  const years = [...new Set(allYearMonths.map(m => m.slice(0,4)))].sort();
  const ytabs = document.getElementById('year-tabs');
  years.forEach(y => {
    const b = document.createElement('button');
    b.className = 'year-tab';
    b.textContent = y;
    b.onclick = () => toggleYear(y, b);
    ytabs.appendChild(b);
  });

  // Month grid
  buildMonthGrid();

  // Branch chips
  const bc = document.getElementById('branch-chips');
  allBranches.forEach(br => {
    const c = document.createElement('div');
    c.className = 'chip';
    c.textContent = br;
    c.dataset.branch = br;
    c.onclick = () => toggleBranch(br, c);
    bc.appendChild(c);
  });

  // 種別チップ
  allTypes = [...new Set(DATA.map(r => r.type).filter(t => t))];
  // 件数多い順にソート
  allTypes.sort((a,b) => DATA.filter(r=>r.type===b).length - DATA.filter(r=>r.type===a).length);
  const tc = document.getElementById('type-chips');
  tc.innerHTML = '';
  allTypes.forEach(t => {
    const c = document.createElement('div');
    c.className = 'chip';
    c.textContent = t;
    c.dataset.type = t;
    c.onclick = () => toggleType(t, c);
    tc.appendChild(c);
  });
  updateTypeCount();
}

function buildMonthGrid() {
  const grid = document.getElementById('month-grid');
  grid.innerHTML = '';
  allYearMonths.forEach(ym => {
    const [y, m] = ym.split('-');
    const c = document.createElement('div');
    c.className = 'month-chip' + (selectedMonths.has(ym) ? ' active' : '');
    c.textContent = `${y.slice(2)}/${m}`;
    c.dataset.ym = ym;
    c.title = `${y}年${parseInt(m)}月`;
    c.onclick = () => { toggleMonth(ym); buildMonthGrid(); updateMonthCount(); update(); };
    grid.appendChild(c);
  });
}

function toggleMonth(ym) {
  if (selectedMonths.has(ym)) selectedMonths.delete(ym);
  else selectedMonths.add(ym);
}

function toggleYear(year, btn) {
  const months = allYearMonths.filter(m => m.startsWith(year));
  const allActive = months.every(m => selectedMonths.has(m));
  months.forEach(m => allActive ? selectedMonths.delete(m) : selectedMonths.add(m));
  document.querySelectorAll('.year-tab').forEach(b => {
    const y = b.textContent;
    const yms = allYearMonths.filter(m => m.startsWith(y));
    b.classList.toggle('active', yms.every(m => selectedMonths.has(m)));
  });
  buildMonthGrid();
  updateMonthCount();
  update();
}

function toggleBranch(br, el) {
  if (selectedBranches.has(br)) { selectedBranches.delete(br); el.classList.remove('active'); }
  else { selectedBranches.add(br); el.classList.add('active'); }
  updateBranchCount();
  update();
}

function resetMonths() {
  selectedMonths.clear();
  allYearMonths.slice(-12).forEach(m => selectedMonths.add(m));
  buildMonthGrid();
  updateMonthCount();
  update();
}

function toggleType(t, el) {
  if (selectedTypes.has(t)) { selectedTypes.delete(t); el.classList.remove('active'); }
  else { selectedTypes.add(t); el.classList.add('active'); }
  updateTypeCount();
  update();
}

function resetTypes() {
  selectedTypes.clear();
  // リセット時はニセコミライ以外を全選択（デフォルト状態に戻す）
  allTypes.forEach(t => { if (t !== 'ニセコミライ') selectedTypes.add(t); }); // ---も含む
  document.querySelectorAll('[data-type]').forEach(c => {
    c.classList.toggle('active', selectedTypes.has(c.dataset.type));
  });
  updateTypeCount();
  update();
}

function updateTypeCount() {
  const n = selectedTypes.size;
  document.getElementById('type-count').textContent = n === 0 ? '全' : n;
}

function resetBranches() {
  selectedBranches.clear();
  document.querySelectorAll('[data-branch]').forEach(c => c.classList.remove('active'));
  updateBranchCount();
  update();
}

function updateMonthCount() {
  document.getElementById('month-count').textContent = selectedMonths.size;
}
function updateBranchCount() {
  const n = selectedBranches.size;
  document.getElementById('branch-count').textContent = n === 0 ? '全' : n;
}

function getFiltered() {
  return DATA.filter(r => {
    if (selectedMonths.size > 0 && !selectedMonths.has(r.ym)) return false;
    if (selectedBranches.size > 0 && !selectedBranches.has(r.branch)) return false;
    if (selectedTypes.size > 0 && !selectedTypes.has(r.type)) return false;
    return true;
  });
}

function update() {
  const filtered = getFiltered();
  updateMonthCount();

  // Summary
  const n = filtered.length;
  const months = [...selectedMonths].sort();
  document.getElementById('filter-summary').innerHTML =
    `<span>${n.toLocaleString()}</span>件 / ${months.length}ヶ月${selectedBranches.size > 0 ? ` / ${selectedBranches.size}支店` : ''}${selectedTypes.size > 0 ? ` / ${selectedTypes.size}種別` : ''}`;

  // KPIs
  document.getElementById('kpi-total').textContent = n.toLocaleString();
  document.getElementById('kpi-period').textContent = months.length > 0 ? `${months[0]} 〜 ${months[months.length-1]}` : '—';
  const adv = filtered.filter(r => r.rank === 'ADV取得').length;
  document.getElementById('kpi-adv').textContent = adv.toLocaleString();
  document.getElementById('kpi-adv-rate').textContent = n > 0 ? `取得率 ${(adv/n*100).toFixed(1)}%` : '—';
  document.getElementById('kpi-avg').textContent = months.length > 0 ? Math.round(n / months.length).toLocaleString() : '—';
  const lost = filtered.filter(r => r.rank === '失注・他決').length;
  document.getElementById('kpi-lost').textContent = lost.toLocaleString();
  document.getElementById('kpi-lost-rate').textContent = n > 0 ? `失注率 ${(lost/n*100).toFixed(1)}%` : '—';

  updateMonthlyChart(filtered, months);
  updateTypeChart(filtered);
  updateRankList(filtered);
  updateStaffLists(filtered);
  updateBranchChart(filtered);
  updateCrosstab(filtered);
  updateCrosstabBranch(filtered);
}

function updateMonthlyChart(filtered, months) {
  // Count per month per type
  const types = [...new Set(filtered.map(r => r.type))].filter(t => t && t !== '---').sort((a,b) => {
    const ca = filtered.filter(r=>r.type===a).length;
    const cb = filtered.filter(r=>r.type===b).length;
    return cb - ca;
  });
  const topTypes = types.slice(0, 8);
  const otherTypes = types.slice(8);

  const datasets = topTypes.map(t => ({
    label: t,
    data: months.map(m => filtered.filter(r => r.ym === m && r.type === t).length),
    backgroundColor: TYPE_COLORS[t] || '#6b7280',
    borderWidth: 0,
    borderRadius: 2,
  }));
  if (otherTypes.length > 0) {
    datasets.push({
      label: 'その他',
      data: months.map(m => filtered.filter(r => r.ym === m && otherTypes.includes(r.type)).length),
      backgroundColor: '#374151',
      borderWidth: 0,
      borderRadius: 2,
    });
  }

  // 月ごとの合計（ラベル表示用）
  const monthTotals = months.map(m => filtered.filter(r => r.ym === m).length);

  const labels = months.map(m => { const [y,mo]=m.split('-'); return `${y.slice(2)}/${parseInt(mo)}`; });

  if (chartMonthly) chartMonthly.destroy();
  const ctx = document.getElementById('chart-monthly').getContext('2d');
  chartMonthly = new Chart(ctx, {
    type: 'bar',
    data: { labels, datasets },
    options: {
      plugins: {
        legend: { labels: { color: '#9097b8', font: { size: 10 }, boxWidth: 10, padding: 8 }, position: 'bottom' },
        // 棒の上に合計数を表示するカスタムプラグイン
        totalLabels: true,
      },
      scales: {
        x: { stacked: true, ticks: { color: '#5c6280', font: { size: 10 } }, grid: { color: 'rgba(255,255,255,0.04)' } },
        y: { stacked: true, ticks: { color: '#5c6280', font: { size: 10 } }, grid: { color: 'rgba(255,255,255,0.06)' } },
      },
      responsive: true, maintainAspectRatio: true,
    },
    plugins: [{
      id: 'totalLabels',
      afterDatasetsDraw(chart) {
        const { ctx, scales: { x, y } } = chart;
        ctx.save();
        ctx.font = 'bold 11px sans-serif';
        ctx.fillStyle = '#e8eaf2';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'bottom';
        monthTotals.forEach((total, i) => {
          if (!total) return;
          const xPos = x.getPixelForValue(i);
          const yPos = y.getPixelForValue(total);
          ctx.fillText(total.toLocaleString(), xPos, yPos - 3);
        });
        ctx.restore();
      }
    }],
  });
}

function updateTypeChart(filtered) {
  const counts = {};
  filtered.forEach(r => { const t = r.type || '---'; counts[t] = (counts[t]||0)+1; });
  const sorted = Object.entries(counts).sort((a,b)=>b[1]-a[1]).filter(([t])=>t!=='---');
  const top = sorted.slice(0, 10);

  if (chartType) chartType.destroy();
  const ctx = document.getElementById('chart-type').getContext('2d');
  chartType = new Chart(ctx, {
    type: 'doughnut',
    data: {
      labels: top.map(([t])=>t),
      datasets: [{ data: top.map(([,v])=>v), backgroundColor: top.map(([t])=>TYPE_COLORS[t]||'#6b7280'), borderWidth: 0, hoverOffset: 6 }]
    },
    options: {
      plugins: {
        legend: { position: 'right', labels: { color: '#9097b8', font: { size: 10 }, boxWidth: 10, padding: 6 } },
        tooltip: { callbacks: { label: ctx => ` ${ctx.label}: ${ctx.raw.toLocaleString()}件` } }
      },
      responsive: true, maintainAspectRatio: true,
      cutout: '60%',
    }
  });
}

function updateRankList(filtered) {
  const counts = {};
  filtered.forEach(r => { const k = r.rank||'---'; if(k!=='---') counts[k]=(counts[k]||0)+1; });
  const sorted = Object.entries(counts).sort((a,b)=>b[1]-a[1]).slice(0, 10);
  const max = sorted[0]?.[1] || 1;
  const el = document.getElementById('rank-list');
  el.innerHTML = sorted.map(([rank, cnt]) =>
    `<div class="rank-row">
      <div class="rank-name" title="${rank}">${rank}</div>
      <div class="rank-bar-wrap"><div class="rank-bar" style="width:${(cnt/max*100).toFixed(1)}%;background:${RANK_COLORS[rank]||'#6b7280'}"></div></div>
      <div class="rank-count">${cnt.toLocaleString()}</div>
    </div>`
  ).join('');
}

function updateStaffLists(filtered) {
  // Tantou
  const tc = {};
  filtered.forEach(r => { if(r.tantou) tc[r.tantou]=(tc[r.tantou]||0)+1; });
  const tSorted = Object.entries(tc).sort((a,b)=>b[1]-a[1]).slice(0,20);
  const tMax = tSorted[0]?.[1]||1;
  document.getElementById('tantou-list').innerHTML = tSorted.map(([n,c]) =>
    `<div class="staff-row">
      <div class="staff-name" title="${n}">${n}</div>
      <div class="staff-bar-wrap"><div class="staff-bar staff-bar-t" style="width:${(c/tMax*100).toFixed(1)}%"></div></div>
      <div class="staff-count">${c}</div>
    </div>`
  ).join('');

  // Meibo
  const mc = {};
  filtered.forEach(r => { if(r.meibo) mc[r.meibo]=(mc[r.meibo]||0)+1; });
  const mSorted = Object.entries(mc).sort((a,b)=>b[1]-a[1]).slice(0,20);
  const mMax = mSorted[0]?.[1]||1;
  document.getElementById('meibo-list').innerHTML = mSorted.map(([n,c]) =>
    `<div class="staff-row">
      <div class="staff-name" title="${n}">${n}</div>
      <div class="staff-bar-wrap"><div class="staff-bar staff-bar-m" style="width:${(c/mMax*100).toFixed(1)}%"></div></div>
      <div class="staff-count">${c}</div>
    </div>`
  ).join('');
}


function updateCrosstabBranch(filtered) {
  const months = [...selectedMonths].sort();
  // Get branches sorted by total desc
  const branchTotals = {};
  filtered.forEach(r => { if(r.branch) branchTotals[r.branch] = (branchTotals[r.branch]||0)+1; });
  const branches = Object.entries(branchTotals).sort((a,b)=>b[1]-a[1]).map(([b])=>b);

  // Build matrix
  const matrix = {};
  const monthTotals = {};
  filtered.forEach(r => {
    if(!r.ym || !r.branch) return;
    if(!matrix[r.ym]) matrix[r.ym] = {};
    matrix[r.ym][r.branch] = (matrix[r.ym][r.branch]||0)+1;
    monthTotals[r.ym] = (monthTotals[r.ym]||0)+1;
  });

  const allVals = [];
  months.forEach(m => branches.forEach(b => { if(matrix[m]?.[b]) allVals.push(matrix[m][b]); }));
  const maxVal = Math.max(...allVals, 1);

  function heatClass(v) {
    if(!v) return 'cell-zero';
    const r = v / maxVal;
    if(r >= 0.6) return 'cell-heat-4';
    if(r >= 0.3) return 'cell-heat-3';
    if(r >= 0.1) return 'cell-heat-2';
    return 'cell-heat-1';
  }

  const table = document.getElementById('crosstab-branch');
  let html = '<thead><tr><th style="text-align:left;min-width:72px">月</th>';
  branches.forEach(b => { html += `<th>${b}</th>`; });
  html += '<th style="color:var(--accent)">合計</th></tr></thead>';

  html += '<tbody>';
  months.forEach(m => {
    const [y,mo] = m.split('-');
    html += `<tr><td>${y.slice(2)}/${parseInt(mo)}月</td>`;
    branches.forEach(b => {
      const v = matrix[m]?.[b] || 0;
      html += `<td class="${heatClass(v)}">${v > 0 ? v.toLocaleString() : '—'}</td>`;
    });
    html += `<td style="color:var(--accent);font-weight:600">${(monthTotals[m]||0).toLocaleString()}</td></tr>`;
  });
  html += '</tbody>';

  html += '<tfoot><tr><td>合計</td>';
  branches.forEach(b => {
    const total = months.reduce((s,m)=>s+(matrix[m]?.[b]||0),0);
    html += `<td>${total.toLocaleString()}</td>`;
  });
  const grand = months.reduce((s,m)=>s+(monthTotals[m]||0),0);
  html += `<td>${grand.toLocaleString()}</td></tr></tfoot>`;

  table.innerHTML = html;
}

function updateCrosstab(filtered) {
  const months = [...selectedMonths].sort();
  // Get types sorted by total desc, exclude '---'
  const typeTotals = {};
  filtered.forEach(r => { if(r.type && r.type !== '---') typeTotals[r.type] = (typeTotals[r.type]||0)+1; });
  const types = Object.entries(typeTotals).sort((a,b)=>b[1]-a[1]).map(([t])=>t);

  // Build matrix
  const matrix = {}; // matrix[month][type] = count
  const monthTotals = {};
  filtered.forEach(r => {
    if(!r.ym || r.type === '---') return;
    if(!matrix[r.ym]) matrix[r.ym] = {};
    matrix[r.ym][r.type] = (matrix[r.ym][r.type]||0)+1;
    monthTotals[r.ym] = (monthTotals[r.ym]||0)+1;
  });

  // Max value for heat coloring
  const allVals = [];
  months.forEach(m => types.forEach(t => { if(matrix[m]?.[t]) allVals.push(matrix[m][t]); }));
  const maxVal = Math.max(...allVals, 1);

  function heatClass(v) {
    if(!v) return 'cell-zero';
    const r = v / maxVal;
    if(r >= 0.6) return 'cell-heat-4';
    if(r >= 0.3) return 'cell-heat-3';
    if(r >= 0.1) return 'cell-heat-2';
    return 'cell-heat-1';
  }

  const table = document.getElementById('crosstab');

  // Header
  let html = '<thead><tr><th style="text-align:left;min-width:72px">月</th>';
  types.forEach(t => { html += `<th>${t}</th>`; });
  html += '<th style="color:var(--accent)">合計</th></tr></thead>';

  // Body
  html += '<tbody>';
  months.forEach(m => {
    const [y,mo] = m.split('-');
    const label = `${y.slice(2)}/${parseInt(mo)}月`;
    html += `<tr><td>${label}</td>`;
    types.forEach(t => {
      const v = matrix[m]?.[t] || 0;
      html += `<td class="${heatClass(v)}">${v > 0 ? v.toLocaleString() : '—'}</td>`;
    });
    const rowTotal = monthTotals[m] || 0;
    html += `<td style="color:var(--accent);font-weight:600">${rowTotal.toLocaleString()}</td></tr>`;
  });
  html += '</tbody>';

  // Footer totals
  html += '<tfoot><tr><td>合計</td>';
  types.forEach(t => {
    const total = months.reduce((s,m)=>s+(matrix[m]?.[t]||0),0);
    html += `<td>${total.toLocaleString()}</td>`;
  });
  const grandTotal = months.reduce((s,m)=>s+(monthTotals[m]||0),0);
  html += `<td>${grandTotal.toLocaleString()}</td></tr></tfoot>`;

  table.innerHTML = html;
}

init();
</script>
</body>
</html>
