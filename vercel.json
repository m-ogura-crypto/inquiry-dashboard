<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">{
  "functions": {
    "api/kintone.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/kintone", "destination": "/api/kintone" }
  ]
}
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>お問合せ分析ダッシュボード</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
  :root {
    --bg: #0f1117;
    --bg2: #1a1d27;
    --bg3: #232737;
    --bg4: #2d3147;
    --text: #e8eaf2;
    --text2: #9097b8;
    --text3: #5c6280;
    --accent: #6c8fff;
    --accent2: #a78bfa;
    --green: #34d399;
    --amber: #fbbf24;
    --coral: #f87171;
    --teal: #22d3ee;
    --border: rgba(108,143,255,0.15);
    --border2: rgba(108,143,255,0.08);
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--bg); color: var(--text); font-family: 'Hiragino Kaku Gothic ProN', 'Noto Sans JP', sans-serif; font-size: 13px; min-height: 100vh; }

  /* Layout */
  .app { display: grid; grid-template-columns: 260px 1fr; min-height: 100vh; }
  .sidebar { background: var(--bg2); border-right: 1px solid var(--border); padding: 20px 16px; display: flex; flex-direction: column; gap: 20px; position: sticky; top: 0; height: 100vh; overflow-y: auto; }
  .main { padding: 20px; display: flex; flex-direction: column; gap: 16px; }

  /* Sidebar */
  .logo { font-size: 14px; font-weight: 700; color: var(--text); letter-spacing: .03em; padding-bottom: 16px; border-bottom: 1px solid var(--border2); display: flex; align-items: center; gap: 8px; }
  .logo svg { opacity: 0.8; }
  .filter-group { display: flex; flex-direction: column; gap: 8px; }
  .filter-label { font-size: 11px; font-weight: 600; letter-spacing: .08em; color: var(--text3); text-transform: uppercase; }
  .filter-chips { display: flex; flex-wrap: wrap; gap: 4px; max-height: 180px; overflow-y: auto; }
  .chip { font-size: 12px; padding: 4px 9px; border-radius: 4px; border: 1px solid var(--border); color: var(--text2); cursor: pointer; transition: all .15s; background: transparent; white-space: nowrap; user-select: none; }
  .chip:hover { border-color: var(--accent); color: var(--accent); }
  .chip.active { background: rgba(108,143,255,0.18); border-color: var(--accent); color: var(--accent); font-weight: 600; }
  .chip-all { border-color: var(--border2); font-size: 10px; }
  .reset-btn { font-size: 12px; color: var(--text3); background: none; border: 1px solid var(--border2); border-radius: 4px; padding: 4px 10px; cursor: pointer; transition: all .15s; margin-top: 4px; }
  .reset-btn:hover { color: var(--coral); border-color: var(--coral); }
  .count-badge { display: inline-block; background: rgba(108,143,255,0.2); color: var(--accent); font-size: 11px; border-radius: 3px; padding: 1px 5px; margin-left: 4px; }
  .scrollbox { max-height: 150px; overflow-y: auto; display: flex; flex-wrap: wrap; gap: 4px; padding-right: 4px; }
  .scrollbox::-webkit-scrollbar { width: 4px; }
  .scrollbox::-webkit-scrollbar-track { background: var(--bg3); }
  .scrollbox::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  /* KPI row */
  .kpi-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
  .kpi { background: var(--bg2); border: 1px solid var(--border2); border-radius: 8px; padding: 14px 16px; }
  .kpi-label { font-size: 12px; color: var(--text3); margin-bottom: 6px; }
  .kpi-value { font-size: 26px; font-weight: 700; color: var(--text); letter-spacing: -.02em; }
  .kpi-sub { font-size: 12px; color: var(--text3); margin-top: 4px; }
  .kpi-accent { border-top: 2px solid var(--accent); }
  .kpi-green { border-top: 2px solid var(--green); }
  .kpi-amber { border-top: 2px solid var(--amber); }
  .kpi-coral { border-top: 2px solid var(--coral); }

  /* Chart cards */
  .chart-row { display: grid; gap: 12px; }
  .chart-row-2 { grid-template-columns: 1fr 1fr; }
  .chart-row-3 { grid-template-columns: 1fr 1fr 1fr; }
  .card { background: var(--bg2); border: 1px solid var(--border2); border-radius: 8px; padding: 16px; }
  .card-title { font-size: 13px; font-weight: 600; color: var(--text2); margin-bottom: 14px; letter-spacing: .03em; }
  .card-full { grid-column: 1 / -1; }
  canvas { max-height: 260px; }

  /* Rank chart */
  .rank-list { display: flex; flex-direction: column; gap: 7px; }
  .rank-row { display: flex; align-items: center; gap: 8px; }
  .rank-name { font-size: 12px; color: var(--text2); width: 90px; flex-shrink: 0; text-align: right; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .rank-bar-wrap { flex: 1; background: var(--bg3); border-radius: 3px; height: 12px; overflow: hidden; }
  .rank-bar { height: 100%; border-radius: 3px; transition: width .4s cubic-bezier(.4,0,.2,1); }
  .rank-count { font-size: 12px; color: var(--text3); width: 38px; text-align: right; flex-shrink: 0; }

  /* Staff table */
  .staff-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .staff-list { display: flex; flex-direction: column; gap: 5px; }
  .staff-row { display: flex; align-items: center; gap: 8px; }
  .staff-name { font-size: 12px; color: var(--text2); flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .staff-bar-wrap { width: 80px; background: var(--bg3); border-radius: 3px; height: 10px; flex-shrink: 0; overflow: hidden; }
  .staff-bar { height: 100%; border-radius: 3px; transition: width .4s; }
  .staff-bar-t { background: linear-gradient(90deg, var(--accent), var(--accent2)); }
  .staff-bar-m { background: linear-gradient(90deg, var(--teal), var(--green)); }
  .staff-count { font-size: 12px; color: var(--text3); width: 32px; text-align: right; flex-shrink: 0; }
  .staff-subtitle { font-size: 11px; font-weight: 600; letter-spacing: .08em; color: var(--text3); text-transform: uppercase; margin-bottom: 8px; }


  /* Update date bar */
  .update-bar { display:flex; align-items:center; gap:10px; background:var(--bg2); border:1px solid var(--border2); border-left:3px solid var(--accent); border-radius:6px; padding:8px 16px; }
  .update-label { font-size:11px; color:var(--text3); letter-spacing:.06em; flex-shrink:0; }
  .update-date { font-size:13px; font-weight:600; color:var(--accent); }

  @keyframes spin { to { transform: rotate(360deg); } }
  /* Loading overlay */
  .loading-overlay { position:fixed; inset:0; background:var(--bg); z-index:1000; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:20px; transition:opacity .4s ease; }
  .loading-overlay.hidden { opacity:0; pointer-events:none; }
  .loading-spinner { width:48px; height:48px; border:3px solid var(--border); border-top-color:var(--accent); border-radius:50%; animation:spin 0.8s linear infinite; }
  .loading-title { font-size:15px; font-weight:600; color:var(--text); }
  .loading-sub { font-size:12px; color:var(--text3); }
  .loading-bar-wrap { width:200px; height:3px; background:var(--border2); border-radius:2px; overflow:hidden; }
  .loading-bar { height:100%; background:linear-gradient(90deg,var(--accent),var(--accent2)); border-radius:2px; animation:loading-progress 2s ease-in-out infinite; }
  @keyframes loading-progress { 0%{width:0%;margin-left:0} 50%{width:60%;margin-left:20%} 100%{width:0%;margin-left:100%} }

  .kintone-btn { display:flex; align-items:center; gap:7px; font-size:12px; color:#fff; background:linear-gradient(135deg,#0062b3,#0091d5); border:none; border-radius:6px; padding:8px 12px; cursor:pointer; transition:all .15s; width:100%; font-weight:600; letter-spacing:.03em; }
  .kintone-btn:hover { opacity:.85; }
  .kintone-btn:disabled { opacity:.5; cursor:wait; }
  /* CSV upload */
  .csv-upload-btn { display:flex; align-items:center; gap:7px; font-size:12px; color:var(--accent); border:1px dashed rgba(108,143,255,0.4); border-radius:6px; padding:7px 12px; cursor:pointer; transition:all .15s; }
  .csv-upload-btn:hover { background:rgba(108,143,255,0.08); border-color:var(--accent); }
  .csv-status { font-size:11px; color:var(--text3); margin-top:4px; }
  .csv-hint { font-size:10px; color:var(--text3); margin-top:4px; line-height:1.5; opacity:.7; }
  .csv-ok { color: var(--green) !important; }
  .csv-err { color: var(--coral) !important; }
  /* Cross tab */
  #crosstab th, #crosstab td { padding: 6px 12px; font-size: 12px; border-bottom: 1px solid var(--border2); }
  #crosstab thead th { position: sticky; top: 0; background: var(--bg2); color: var(--text3); font-weight: 600; letter-spacing: .06em; z-index: 2; border-bottom: 1px solid var(--border); }
  #crosstab thead th:first-child { position: sticky; left: 0; z-index: 3; background: var(--bg2); }
  #crosstab tbody td:first-child { position: sticky; left: 0; background: var(--bg2); color: var(--text2); font-weight: 600; z-index: 1; border-right: 1px solid var(--border); }
  #crosstab tbody td { color: var(--text2); text-align: right; }
  #crosstab tfoot td { position: sticky; bottom: 0; background: var(--bg3); color: var(--text); font-weight: 700; text-align: right; border-top: 1px solid var(--border); z-index: 1; }
  #crosstab tfoot td:first-child { position: sticky; left: 0; z-index: 2; background: var(--bg3); text-align: left; }
  #crosstab tbody tr:hover td { background: var(--bg3); }
  #crosstab tbody tr:hover td:first-child { background: var(--bg3); }
  .cell-heat-1 { color: #6c8fff !important; }
  .cell-heat-2 { color: #a78bfa !important; }
  .cell-heat-3 { color: #fbbf24 !important; }
  .cell-heat-4 { color: #f87171 !important; }
  .cell-zero { color: var(--text3) !important; }

  ::-webkit-scrollbar { width: 5px; height: 5px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

  /* Month selector */
  .month-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 3px; }
  .month-chip { font-size: 11px; padding: 5px 3px; border-radius: 4px; border: 1px solid var(--border2); color: var(--text3); cursor: pointer; transition: all .15s; background: transparent; text-align: center; user-select: none; }
  .month-chip:hover { border-color: var(--accent); color: var(--accent); }
  .month-chip.active { background: rgba(108,143,255,0.18); border-color: var(--accent); color: var(--accent); font-weight: 600; }
  .year-tabs { display: flex; gap: 4px; flex-wrap: wrap; margin-bottom: 6px; }
  .year-tab { font-size: 11px; padding: 3px 9px; border-radius: 4px; border: 1px solid var(--border2); color: var(--text3); cursor: pointer; transition: all .15s; background: transparent; }
  .year-tab.active { background: rgba(167,139,250,0.2); border-color: var(--accent2); color: var(--accent2); }
  .divider { height: 1px; background: var(--border2); }
  .summary-text { font-size: 12px; color: var(--text3); }
  .summary-text span { color: var(--accent); font-weight: 600; }
</style>
</head>
<body>
<div class="loading-overlay" id="loading-overlay">
  <div class="loading-spinner"></div>
  <div class="loading-title">kintoneからデータを取得中...</div>
  <div class="loading-bar-wrap"><div class="loading-bar"></div></div>
  <div class="loading-sub" id="loading-sub">しばらくお待ちください</div>
</div>
<div class="app">
  <!-- SIDEBAR -->
  <aside class="sidebar">
    <div class="logo">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><rect x="1" y="1" width="7" height="7" rx="1.5" fill="var(--accent)" opacity=".9"/><rect x="10" y="1" width="7" height="7" rx="1.5" fill="var(--accent2)" opacity=".7"/><rect x="1" y="10" width="7" height="7" rx="1.5" fill="var(--teal)" opacity=".7"/><rect x="10" y="10" width="7" height="7" rx="1.5" fill="var(--green)" opacity=".5"/></svg>
      お問合せ分析
    </div>

    <!-- データ更新 -->
    <div class="filter-group">
      <div class="filter-label">データ更新</div>
      <button class="kintone-btn" id="kintone-btn" onclick="loadFromKintone()">
        <svg width="13" height="13" viewBox="0 0 16 16" fill="none" style="flex-shrink:0"><path d="M13.5 8A5.5 5.5 0 1 1 8 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M10 2h4v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M14 2l-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        kintoneから取得
      </button>
      <div class="csv-status" id="csv-status">ボタンを押すと最新データを取得</div>
      <div class="divider" style="margin:8px 0"></div>
      <label class="csv-upload-btn" id="csv-label">
        <svg width="13" height="13" viewBox="0 0 16 16" fill="none" style="flex-shrink:0"><path d="M8 2v8M5 7l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M3 12h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        CSVで手動更新
        <input type="file" id="csv-input" accept=".csv" style="display:none">
      </label>
    </div>

    <div class="divider"></div>


    <!-- 期間（月選択） -->
    <div class="filter-group">
      <div class="filter-label">期間（月）<span class="count-badge" id="month-count">0</span></div>
      <div class="year-tabs" id="year-tabs"></div>
      <div class="month-grid" id="month-grid"></div>
      <button class="reset-btn" onclick="resetMonths()">期間リセット</button>
    </div>

    <div class="divider"></div>

    <!-- 支店 -->
    <div class="filter-group">
      <div class="filter-label">支店<span class="count-badge" id="branch-count">全</span></div>
      <div class="scrollbox" id="branch-chips"></div>
      <button class="reset-btn" onclick="resetBranches()">支店リセット</button>
    </div>

    <div class="divider"></div>

    <!-- 問合わせ種別 -->
    <div class="filter-group">
      <div class="filter-label">問合わせ種別<span class="count-badge" id="type-count">全</span></div>
      <div class="scrollbox" id="type-chips"></div>
      <button class="reset-btn" onclick="resetTypes()">種別リセット</button>
    </div>

    <div class="divider"></div>

    <!-- 集計件数 -->
    <div class="summary-text" id="filter-summary">全データ表示中</div>
  </aside>

  <!-- MAIN -->
  <main class="main">
    <!-- 更新日バー -->
    <div class="update-bar">
      <span class="update-label">データ更新日</span>
      <span class="update-date" id="update-date">埋め込みデータ（初期値）</span>
    </div>

    <!-- KPIs -->
    <div class="kpi-row">
      <div class="kpi kpi-accent">
        <div class="kpi-label">総問合せ件数</div>
        <div class="kpi-value" id="kpi-total">—</div>
        <div class="kpi-sub" id="kpi-period">—</div>
      </div>
      <div class="kpi kpi-green">
        <div class="kpi-label">ADV取得件数</div>
        <div class="kpi-value" id="kpi-adv">—</div>
        <div class="kpi-sub" id="kpi-adv-rate">—</div>
      </div>
      <div class="kpi kpi-amber">
        <div class="kpi-label">月平均件数</div>
        <div class="kpi-value" id="kpi-avg">—</div>
        <div class="kpi-sub">選択期間の平均</div>
      </div>
      <div class="kpi kpi-coral">
        <div class="kpi-label">失注件数</div>
        <div class="kpi-value" id="kpi-lost">—</div>
        <div class="kpi-sub" id="kpi-lost-rate">—</div>
      </div>
    </div>

    <!-- 月別推移 -->
    <div class="card">
      <div class="card-title">月別問合せ数推移（問合わせ種別）</div>
      <canvas id="chart-monthly" style="max-height:220px"></canvas>
    </div>

    <!-- 種別 + ランク -->
    <div class="chart-row chart-row-2">
      <div class="card">
        <div class="card-title">問合わせ種別</div>
        <canvas id="chart-type" style="max-height:240px"></canvas>
      </div>
      <div class="card">
        <div class="card-title">ランク別件数</div>
        <div class="rank-list" id="rank-list"></div>
      </div>
    </div>

        <!-- 月別×支店 グラフ -->
    <div class="card">
      <div class="card-title">支店別 × 問合わせ種別 件数</div>
      <canvas id="chart-branch" style="max-height:220px"></canvas>
    </div>

    <!-- 担当者別 + 名簿取得者別 -->
    <div class="card">
      <div class="card-title">名簿取得者別 / 担当者別（上位20名）</div>
      <div class="staff-grid" id="staff-grid">
        <div>
          <div class="staff-subtitle">名簿取得者</div>
          <div class="staff-list" id="meibo-list"></div>
        </div>
        <div>
          <div class="staff-subtitle">主担当者</div>
          <div class="staff-list" id="tantou-list"></div>
        </div>
      </div>
    </div>

    <!-- 月別×種別 クロス集計 -->
    <div class="card">
      <div class="card-title">月別 × 問合わせ種別 件数</div>
      <div style="overflow-x:auto;overflow-y:auto;max-height:420px;">
        <table id="crosstab" style="border-collapse:collapse;white-space:nowrap;min-width:100%"></table>
      </div>
    </div>

    <!-- 月別×支店 クロス集計 -->
    <div class="card">
      <div class="card-title">月別 × 支店別 件数</div>
      <div style="overflow-x:auto;overflow-y:auto;max-height:420px;">
        <table id="crosstab-branch" style="border-collapse:collapse;white-space:nowrap;min-width:100%"></table>
      </div>
    </div>

  </main>
</div>

